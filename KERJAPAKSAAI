-- ============================================================
-- VALUE LISTENER
-- ============================================================
addHook(function(type, name, value)
    if name == "break_threshold" then
        Config.breakThreshold = tonumber(value) or 10
        saved:set("break_threshold", Config.breakThreshold)
        saved:save()
        updateStatus(true)
    elseif name == "x_coords" then
        Config.xCoords = tonumber(value) or 2
        saved:set("x_coords", Config.xCoords)
        saved:save()
    elseif name == "y_coords" then
        Config.yCoords = tonumber(value) or -1
        saved:set("y_coords", Config.yCoords)
        saved:save()
    elseif name == "only_retrieve" then
        Config.onlyRetrieve = value
        saved:set("only_retrieve", Config.onlyRetrieve)
        saved:save()
        if State.running then
            if Config.onlyRetrieve then setFarmState(false) else setFarmState(true) end
        end
        updateStatus(true)
    elseif name == "enable_autofind_backup" then
        Config.enableAutoFindBackup = value
        saved:set("enable_autofind_backup", Config.enableAutoFindBackup)
        saved:save()
        updateStatus(true)
    elseif name == "gaia_enable" then
        Config.gaiaEnabled = value
        saved:set("gaia_enabled", Config.gaiaEnabled)
        saved:save()
        updateStatus(true)
    elseif name == "gaia_dropx" then
        Config.gaiaDropX = tonumber(value) or 52
        saved:set("gaia_drop_x", Config.gaiaDropX)
        saved:save()
        State.currentDropX = Config.gaiaDropX
    elseif name == "gaia_dropy" then
        Config.gaiaDropY = tonumber(value) or 23
        saved:set("gaia_drop_y", Config.gaiaDropY)
        saved:save()
    elseif name == "ut_enable" then
        Config.utEnabled = value
        saved:set("ut_enabled", Config.utEnabled)
        saved:save()
        updateStatus(true)
    elseif name == "ut_dropx" then
        Config.utDropX = tonumber(value) or 0
        saved:set("ut_drop_x", Config.utDropX)
        saved:save()
    elseif name == "ut_dropy" then
        Config.utDropY = tonumber(value) or 0
        saved:set("ut_drop_y", Config.utDropY)
        saved:save()
    elseif name == "toggle_start" then
        if value then
            startFarm()
        else
            if State.running then stopFarm() end
        end
        updateStatus()
    elseif name == "btn_stop" then
        if State.running then stopFarm() end
        updateStatus()
    elseif name == "btn_refresh" then
        updateStatus(true)
        growtopia.notify("Status refreshed")
    elseif name == "btn_check_status" then
        local blockInv = invCount(ITEMS.BLOCK_ID)
        local seedInv = invCount(ITEMS.SEED_ID)
        local farmState = getFarmState()
        local findState = getAutoFind()
        local msg = string.format(
            "Break: %d/%d | Block: %d | Seed: %d | Farm: %s | GAIA: %s | UT: %s | Find: %s",
            State.breakCount,
            Config.breakThreshold,
            blockInv,
            seedInv,
            farmState and "ON" or "OFF",
            Config.gaiaEnabled and "ON" or "OFF",
            Config.utEnabled and "ON" or "OFF",
            findState and "ON" or "OFF"
        )
        growtopia.notify(msg)
    end
end, "onValue")

