-- AUTO FARM CONTROLLER (LGRID + GAIA + UT) - STABLE
local pref = require("preferences")
local json = require("json")
local saved = pref:new("auto_farm_controller.json")

local Config = {
    breakThreshold  = tonumber(saved:get("break_threshold", 500)),
    gaiaEnabled     = saved:get("gaia_enabled", true),
    gaiaDropX       = tonumber(saved:get("gaia_drop_x", 0)),
    gaiaDropY       = tonumber(saved:get("gaia_drop_y", 0)),
    utEnabled       = saved:get("ut_enabled", true),
    utDropX         = tonumber(saved:get("ut_drop_x", 0)),
    utDropY         = tonumber(saved:get("ut_drop_y", 0)),
    onlyRetrieve    = saved:get("only_retrieve", false),
}

local State = {
    running         = false,
    retrieveBusy    = false,
    farmingPaused   = false,
    breakCount      = 0,
    startWorld      = "",
    startX          = 0,
    startY          = 0,
}

local ITEMS = {
    GAIA_ID     = 6946,
    UT_ID       = 6948,
    BLOCK_ID    = 5666,
    SEED_ID     = 5667,
    GAIA_DIALOG = "itemsucker_seed",
    UT_DIALOG   = "itemsucker_block",
}

local AUTOFARM_ALIAS = "autofarm_start"

local blockCountTimer = 0
local cachedBlockCount = 0

function getLocalPos()
    local p = getLocal()
    if not p then return 0, 0 end
    return p.posX // 32, p.posY // 32
end

function invCount(itemID)
    for _, v in pairs(getInventory()) do
        if v.id == itemID then return v.amount end
    end
    return 0
end

function countBlocks()
    local n = 0
    for _, t in pairs(getTiles()) do
        if t and t.fg == ITEMS.BLOCK_ID then
            n = n + 1
        end
    end
    return n
end

function safeWarp(worldStr)
    local w, d = worldStr:match("([^|]+)|?(.*)")
    if d == "" or d == nil then d = "0" end
    if string.lower(GetWorldName()) == string.lower(w) then return true end
    for attempt = 1, 3 do
        sendPacket(3, "action|join_request\nname|"..w.."|"..d.."\ninvitedWorld|0")
        sleep(3000)
        for _ = 1, 20 do
            if string.lower(GetWorldName()) == string.lower(w) then
                sleep(1000)
                return true
            end
            sleep(200)
        end
    end
    return false
end

function safeMove(x, y)
    for attempt = 1, 3 do
        local px, py = getLocalPos()
        if px == x and py == y then return true end
        FindPath(x, y)
        sleep(100)
        local start = getTime()
        while getTime() - start < 8000 do
            px, py = getLocalPos()
            if px == x and py == y then
                sleep(200)
                return true
            end
            sleep(100)
        end
        sleep(500)
    end
    return false
end

function findDropTile(baseX, baseY)
    for offset = 0, 20 do
        local tx = baseX - offset
        if tx < 0 then break end
        local t = tile.getTile(tx, baseY)
        if t and t.fg == 0 then
            local hasObject = false
            for _, obj in pairs(getObjectList()) do
                if obj.pos.x == tx and obj.pos.y == baseY then
                    hasObject = true
                    break
                end
            end
            if not hasObject then
                return tx, baseY
            end
        end
    end
    local cx, cy = getLocalPos()
    return cx, cy
end

function dropItem(itemID, amount, baseX, baseY)
    if amount <= 0 then return end
    local dx, dy = findDropTile(baseX, baseY)
    if not safeMove(dx, dy) then
        dx, dy = getLocalPos()
    end
    sendPacket(2, "action|drop\nitemID|"..itemID)
    sleep(500)
    sendPacket(2, "action|dialog_return\ndialog_name|drop_item\nitemID|"..itemID.."|\ncount|"..amount)
    sleep(300)
end

function savePosition()
    State.startWorld = GetWorldName()
    State.startX, State.startY = getLocalPos()
end

function ensurePosition()
    for attempt = 1, 10 do
        local curWorld = GetWorldName()
        local cx, cy   = getLocalPos()
        if curWorld == State.startWorld and cx == State.startX and cy == State.startY then
            sleep(300)
            cx, cy = getLocalPos()
            if cx == State.startX and cy == State.startY then
                return true
            end
        end
        if not safeWarp(State.startWorld) then
            sleep(1000)
        else
            if safeMove(State.startX, State.startY) then
                sleep(300)
                local vx, vy = getLocalPos()
                if vx == State.startX and vy == State.startY then
                    return true
                end
            end
        end
        sleep(1000)
    end
    return false
end

function getFarmState()
    return getValue(0, AUTOFARM_ALIAS)
end

function setFarmState(on)
    local current = getFarmState()
    if on and not current then
        editValue(AUTOFARM_ALIAS, true)
        sleep(300)
        State.farmingPaused = false
    elseif not on and current then
        editValue(AUTOFARM_ALIAS, false)
        sleep(300)
        State.farmingPaused = true
    end
end

function pauseFarm()
    if not State.farmingPaused then
        setFarmState(false)
        sleep(300)
    end
end

function resumeFarm()
    if not State.running or State.retrieveBusy then return end
    if not Config.onlyRetrieve then
        local cx, cy = getLocalPos()
        if cx == State.startX and cy == State.startY and
           string.lower(GetWorldName()) == string.lower(State.startWorld) then
            setFarmState(true)
        end
    end
end

local lastBlockCount = 0
local blockCheckTimer = 0

function updateBreakCounter()
    if not State.running or State.retrieveBusy then return end
    blockCheckTimer = blockCheckTimer + 0.1
    if blockCheckTimer >= 0.5 then
        blockCheckTimer = 0
        local now = countBlocks()
        if now < lastBlockCount then
            State.breakCount = State.breakCount + (lastBlockCount - now)
            updateStatus()
        end
        lastBlockCount = now
    end
end

function checkSeedFull()
    local seedInv = invCount(ITEMS.SEED_ID)
    if seedInv >= 200 and Config.gaiaEnabled then
        pauseFarm()
        dropItem(ITEMS.SEED_ID, seedInv, Config.gaiaDropX, Config.gaiaDropY)
        if ensurePosition() then
            resumeFarm()
        end
        sleep(500)
    end
end

local dialogData = {
    stock = 0,
    tilex = 0,
    tiley = 0,
    cfg   = nil,
    ready = false
}

addHook(function(var)
    if var.v1 ~= "OnDialogRequest" or not var.v2 then return false end
    local txt    = var.v2
    local isGaia = txt:find("end_dialog|"..ITEMS.GAIA_DIALOG)
    local isUT   = txt:find("end_dialog|"..ITEMS.UT_DIALOG)
    if not isGaia and not isUT then return false end
    local cfg = isGaia and
        {id=ITEMS.GAIA_ID, dialog=ITEMS.GAIA_DIALOG, item_id=ITEMS.SEED_ID} or
        {id=ITEMS.UT_ID,   dialog=ITEMS.UT_DIALOG,   item_id=ITEMS.BLOCK_ID}
    local tilex = txt:match("embed_data|tilex|(%d+)")
    local tiley = txt:match("embed_data|tiley|(%d+)")
    local stock = tonumber(txt:match("contains%s+(%d+)")) or 0
    if tilex and tiley then
        dialogData.stock = stock
        dialogData.tilex = tonumber(tilex)
        dialogData.tiley = tonumber(tiley)
        dialogData.cfg   = cfg
        dialogData.ready = true
    end
    return false
end, "onVariant")

function waitForDialog(timeout)
    dialogData.ready = false
    local start = getTime()
    while getTime() - start < timeout do
        if dialogData.ready then
            dialogData.ready = false
            return true
        end
        sleep(50)
    end
    return false
end

