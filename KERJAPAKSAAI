addHook(function(type, name, value)
    if name == "break_threshold" then
        Config.breakThreshold = tonumber(value) or 500
        saved:set("break_threshold", Config.breakThreshold)
        saved:save()
        updateStatus()
    elseif name == "only_retrieve" then
        Config.onlyRetrieve = value
        saved:set("only_retrieve", Config.onlyRetrieve)
        saved:save()
        if State.running then
            if Config.onlyRetrieve then setFarmState(false)
            else setFarmState(true) end
        end
        updateStatus()
    elseif name == "gaia_enable" then
        Config.gaiaEnabled = value
        saved:set("gaia_enabled", Config.gaiaEnabled)
        saved:save()
        updateStatus()
    elseif name == "gaia_dropx" then
        Config.gaiaDropX = tonumber(value) or 0
        saved:set("gaia_drop_x", Config.gaiaDropX)
        saved:save()
    elseif name == "gaia_dropy" then
        Config.gaiaDropY = tonumber(value) or 0
        saved:set("gaia_drop_y", Config.gaiaDropY)
        saved:save()
    elseif name == "ut_enable" then
        Config.utEnabled = value
        saved:set("ut_enabled", Config.utEnabled)
        saved:save()
        updateStatus()
    elseif name == "ut_dropx" then
        Config.utDropX = tonumber(value) or 0
        saved:set("ut_drop_x", Config.utDropX)
        saved:save()
    elseif name == "ut_dropy" then
        Config.utDropY = tonumber(value) or 0
        saved:set("ut_drop_y", Config.utDropY)
        saved:save()
    elseif name == "toggle_start" then
        if value then startFarm() else if State.running then stopFarm() end end
        updateStatus()
    elseif name == "btn_stop" then
        if State.running then stopFarm() end
        updateStatus()
    elseif name == "btn_refresh" then
        updateStatus()
        growtopia.notify("Status refreshed")
    end
end, "onValue")

runCoroutine(function()
    sleep(1000)
    updateStatus()
end)

growtopia.notify("Auto Farm Controller ready")
