-- FIX: RETRIEVE GAIA SAMPAI HABIS (LOOP SAMPAI EMPTY)
-- ============================================================
function retrieveGaia()
    if not Config.gaiaEnabled then return false end
    if State.retrieveBusy then return false end
    State.retrieveBusy = true
    pauseFarm()

    local found = false

    local ok, err = pcall(function()
        while true do
            local tiles = getTiles()
            local gaiaFound = false

            for _, t in pairs(tiles) do
                if t and t.fg == ITEMS.GAIA_ID then
                    gaiaFound = true
                    if safeMove(t.x, t.y - 1) then
                        sleep(300)
                        local p = getLocal()
                        dialogData.ready = false
                        sendPacketRaw(false, {
                            type  = 3,
                            value = 32,
                            px    = t.x,
                            py    = t.y,
                            x     = p.posX,
                            y     = p.posY
                        })
                        if waitForDialog(3000) and dialogData.cfg then
                            local stock = dialogData.stock
                            if stock <= 0 then
                                growtopia.notify("GAIA empty, stop retrieve")
                                gaiaFound = false
                                break
                            end
                            local curInv = invCount(ITEMS.SEED_ID)
                            local take   = math.min(stock, 200 - curInv)
                            if take > 0 then
                                local p1 = string.format(
                                    "action|dialog_return\ndialog_name|%s\ntilex|%s|\ntiley|%s|\nbuttonClicked|retrieveitem\n\nchk_enablesucking|1",
                                    ITEMS.GAIA_DIALOG, dialogData.tilex, dialogData.tiley)
                                sendPacket(2, p1)
                                sleep(300)
                                local p2 = string.format(
                                    "action|dialog_return\ndialog_name|itemremovedfromsucker\ntilex|%s|\ntiley|%s|\nitemtoremove|%d",
                                    dialogData.tilex, dialogData.tiley, take)
                                sendPacket(2, p2)
                                sleep(500)
                                dropItem(ITEMS.SEED_ID, take, Config.gaiaDropX, Config.gaiaDropY)
                            else
                                dropItem(ITEMS.SEED_ID, curInv, Config.gaiaDropX, Config.gaiaDropY)
                            end
                        end
                    end
                    found = true
                    break
                end
            end

            if not gaiaFound then
                break
            end
            sleep(300)
        end
    end)

    if not ok then
        growtopia.notify("Retrieve GAIA error: "..tostring(err))
    end

    State.retrieveBusy = false

    if ensurePosition() then
        resumeFarm()
    else
        growtopia.notify("Gagal balik posisi, farm pause")
    end

    return found
end
-- ============================================================

function retrieveUT()
    if not Config.utEnabled then return false end
    if State.retrieveBusy then return false end
    State.retrieveBusy = true
    pauseFarm()

    local found = false

    local ok, err = pcall(function()
        local tiles = getTiles()
        for _, t in pairs(tiles) do
            if t and t.fg == ITEMS.UT_ID then
                if safeMove(t.x, t.y - 1) then
                    local p = getLocal()
                    dialogData.ready = false
                    sendPacketRaw(false, {
                        type  = 3,
                        value = 32,
                        px    = t.x,
                        py    = t.y,
                        x     = p.posX,
                        y     = p.posY
                    })
                    if waitForDialog(3000) and dialogData.cfg then
                        local stock = dialogData.stock
                        if stock > 0 then
                            local curInv = invCount(ITEMS.BLOCK_ID)
                            local need   = 200 - curInv
                            local take   = math.min(stock, need)
                            if take > 0 then
                                local p1 = string.format(
                                    "action|dialog_return\ndialog_name|%s\ntilex|%s|\ntiley|%s|\nbuttonClicked|retrieveitem\n\nchk_enablesucking|1",
                                    ITEMS.UT_DIALOG, dialogData.tilex, dialogData.tiley)
                                sendPacket(2, p1)
                                sleep(300)
                                local p2 = string.format(
                                    "action|dialog_return\ndialog_name|itemremovedfromsucker\ntilex|%s|\ntiley|%s|\nitemtoremove|%d",
                                    dialogData.tilex, dialogData.tiley, take)
                                sendPacket(2, p2)
                                sleep(500)
                            end
                        end
                    end
                end
                found = true
                break
            end
        end
    end)

    if not ok then
        LogToConsole("Retrieve UT error: " .. tostring(err))
    end

    State.retrieveBusy = false

    if ensurePosition() then
        resumeFarm()
    else
        growtopia.notify("Gagal balik posisi, farm pause")
    end

    return found
end

function mainLoop()
    while State.running do
        if not State.retrieveBusy and not State.farmingPaused then
            checkSeedFull()
            updateBreakCounter()

            local blockInv = invCount(ITEMS.BLOCK_ID)
            if Config.utEnabled and blockInv == 0 and not State.retrieveBusy then
                retrieveUT()
                sleep(500)
            end

            if Config.gaiaEnabled and State.breakCount >= Config.breakThreshold and not State.retrieveBusy then
                retrieveGaia()
                State.breakCount = 0
                sleep(500)
            end
        end
        sleep(100)
    end
end

function startFarm()
    if State.running then return end
    State.running      = true
    State.retrieveBusy = false
    State.breakCount   = 0
    lastBlockCount     = countBlocks()
    blockCheckTimer    = 0
    savePosition()
    if not Config.onlyRetrieve then
        setFarmState(true)
    end
    runThread(mainLoop)
    growtopia.notify("Auto Farm started")
    updateStatus()
end

function stopFarm()
    State.running      = false
    State.retrieveBusy = false
    setFarmState(false)
    growtopia.notify("Auto Farm stopped")
    updateStatus()
end

function updateStatus()
    local items = {
        {State.running and "Running" or "Stopped"},
        {"Mode: "..(Config.onlyRetrieve and "Only Retrieve" or "Auto Farm")},
        {"Break: "..State.breakCount.." / "..Config.breakThreshold},
        {"Block: "..invCount(ITEMS.BLOCK_ID).." / 200"},
        {"Seed: "..invCount(ITEMS.SEED_ID).." / 200"},
        {"GAIA: "..(Config.gaiaEnabled and "ON" or "OFF")},
        {"UT: "..(Config.utEnabled and "ON" or "OFF")},
        {"Autofarm: "..(getFarmState() and "ON" or "OFF")},
        {"Pos: "..State.startWorld.." "..State.startX..","..State.startY}
    }
    editValue("status_display", json:encode(items))
end

